  "habitatMap": {
    "title": "Carte de l'habitat",
    "details": "Détails",
    "descriptions": {
      "aquatic": "Vit dans ou sur l'eau — étangs, rivières, marais ou milieux submergés. Les racines peuvent flotter librement ou s'ancrer dans un sol gorgé d'eau.",
      "hygrophytic": "Prospère dans des conditions constamment humides — forêts tropicales, berges de cours d'eau, tourbières. Nécessite une humidité élevée et tolère rarement la sécheresse.",
      "terrestrial": "Pousse enracinée dans le sol dans une grande variété de terres et de conditions. L'habitat le plus courant pour les plantes de jardin et de paysage.",
      "xerophytic": "Adaptée aux environnements secs, arides ou désertiques. Stocke l'eau dans ses feuilles ou tiges et survit de longues périodes sans pluie.",
      "halophytic": "Tolère ou nécessite des sols ou eaux salines — marais côtiers, salins, zones de mangrove.",
      "epiphytic": "Pousse sur d'autres plantes (arbres, branches) sans les parasiter. Absorbe l'humidité et les nutriments de l'air et de la pluie.",
      "parasitic": "Tire une partie ou la totalité de ses nutriments d'une plante hôte, en s'attachant via des structures spécialisées appelées haustoria."
    }
  },
